# Copy to .env and fill in real values. Never commit .env.

# Twitch OAuth application credentials
TWITCH_CLIENT_ID=your_twitch_client_id_here
TWITCH_CLIENT_SECRET=your_twitch_client_secret_here

# Redirect URI registered in the Twitch developer console
TWITCH_REDIRECT_URI=http://localhost:8000/auth/callback

# Signed-cookie session key -- generate with: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET_KEY=change_me_generate_a_random_hex_string

# Comma-separated Twitch login names that receive admin on startup
ADMIN_LOGINS=

# SQLite database file path
DATABASE_URL=sqlite:///./soundlist.db

# Set to "production" in prod; enables stricter cookie flags
APP_ENV=development
